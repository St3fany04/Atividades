package br.edu.faseh.lista;

public class FasehList<T> {
    // Hold the reference to the first node of this List.
    private Node<T> firstNode;
    private Node<T> lastNode;  // New: reference to the last node
    private int totalElements;

    public void insertAtBeginning(T value) {
        Node<T> newNode = new Node<>(value);
        newNode.setNext(firstNode);
        firstNode = newNode;
        
        if (totalElements == 0) {
            lastNode = newNode;
        }
        totalElements++;
    }

    public Node<T> removeAtBeginning() {
        Node<T> aux = firstNode;
        firstNode = firstNode.getNext();
        totalElements--;
        
        if (totalElements == 0) {
            lastNode = null;
        }
        return aux;
    }

    /**
     * Insere um elemento no fim da lista
     * @param value Valor a ser inserido
     */
    public void inserirNoFim(T value) {
        Node<T> newNode = new Node<>(value);
        
        if (totalElements == 0) {
            firstNode = newNode;
        } else {
            lastNode.setNext(newNode);
        }
        
        lastNode = newNode;
        totalElements++;
    }

    /**
     * Remove um elemento da lista baseado na chave (valor)
     * @param chave Valor do elemento a ser removido
     * @return true se removido, false caso contrário
     */
    public boolean removerElemento(T chave) {
        if (totalElements == 0) {
            return false;
        }
        
        // Se o primeiro elemento é o que procuramos
        if (firstNode.getValue().equals(chave)) {
            firstNode = firstNode.getNext();
            totalElements--;
            
            if (totalElements == 0) {
                lastNode = null;
            }
            return true;
        }
        
        // Procura nos demais elementos
        Node<T> currentNode = firstNode;
        Node<T> previousNode = null;
        
        while (currentNode != null) {
            if (currentNode.getValue().equals(chave)) {
                previousNode.setNext(currentNode.getNext());
                totalElements--;
                
                if (currentNode == lastNode) {
                    lastNode = previousNode;
                }
                return true;
            }
            previousNode = currentNode;
            currentNode = currentNode.getNext();
        }
        
        return false; // Elemento não encontrado
    }

    @Override
    public String toString() {
        if(this.totalElements == 0) {
            return "[ ]";
        }

        Node<T> currentNode = firstNode;
        StringBuilder builder = new StringBuilder("[");

        for (int i = 0; i < totalElements; i++) {
            builder.append(currentNode.getValue());
            builder.append(", ");
            currentNode = currentNode.getNext();
        }

        builder.append("]");
        return builder.toString();
    }
}
